+/*
+ * Get the foreground or background colour from the first attached client
+ * that has reported one, for replies when there is no pane (popups).
+ */
+static int
+input_client_colour(int bg)
+{
+	struct client	*c;
+
+	TAILQ_FOREACH(c, &clients, entry) {
+		if (c->session == NULL || (c->flags & CLIENT_CONTROL))
+			continue;
+		if (bg && c->tty.bg != -1)
+			return (c->tty.bg);
+		if (!bg && c->tty.fg != -1)
+			return (c->tty.fg);
+	}
+	return (-1);
+}
