diff --git i/tty-keys.c w/tty-keys.c
index d3a93f1..2b59eb6 100644
--- i/tty-keys.c
+++ w/tty-keys.c
@@ -742,6 +742,26 @@ tty_keys_winsz(struct tty *tty, const char *buf, size_t len, size_t *size)
 }
 
 
+/*
+ * Return non-zero if the @no-query-escape-delay user option is enabled, in
+ * which case the key delay is not inflated while tmux's own terminal probes
+ * are outstanding. Set this on terminals that never answer the probes so
+ * <Esc> keeps honouring escape-time. Uses options_get_only so a missing
+ * option returns NULL rather than calling fatalx.
+ */
+static int
+tty_keys_no_query_delay(void)
+{
+	struct options_entry	*o;
+	const char		*s;
+
+	o = options_get_only(global_s_options, "@no-query-escape-delay");
+	if (o == NULL || options_is_array(o))
+		return (0);
+	s = options_get_string(global_s_options, "@no-query-escape-delay");
+	return (s != NULL && (strcmp(s, "on") == 0 || strcmp(s, "1") == 0));
+}
+
 /* Process at least one key in the buffer. Return 0 if no keys present. */
 int
 tty_keys_next(struct tty *tty)
@@ -976,9 +996,23 @@ partial_key:
 		if (delay < 500)
 			delay = 500;
 	}
-	if ((tty->flags & (TTY_WAITFG|TTY_WAITBG) ||
-	    (tty->flags & TTY_ALL_REQUEST_FLAGS) != TTY_ALL_REQUEST_FLAGS) ||
-	    !TAILQ_EMPTY(&c->input_requests)) {
+	if (!TAILQ_EMPTY(&c->input_requests)) {
+		log_debug("%s: increasing delay (input request)", c->name);
+		if (delay < 500)
+			delay = 500;
+	} else if ((tty->flags & (TTY_WAITFG|TTY_WAITBG) ||
+	    (tty->flags & TTY_ALL_REQUEST_FLAGS) != TTY_ALL_REQUEST_FLAGS) &&
+	    !tty_keys_no_query_delay()) {
+		/*
+		 * tmux normally forces the key delay to 500ms while its own
+		 * terminal probes (DA/DA2/XDA and the OSC 10/11 fg/bg queries)
+		 * are still outstanding, so a probe reply is not chopped up.
+		 * Terminals that never answer these probes (for example WezTerm
+		 * reached through the Windows ConPTY layer) leave the wait flags
+		 * set for the whole TTY_QUERY_TIMEOUT window, and re-arm them on
+		 * every resize, so <Esc> lags ~500ms regardless of escape-time.
+		 * The @no-query-escape-delay user option opts out of that bump.
+		 */
 		log_debug("%s: increasing delay (active query)", c->name);
 		if (delay < 500)
 			delay = 500;
